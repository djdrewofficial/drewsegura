---
import Record from "./Record.astro";
interface Props {
  side?: string;
  title?: string;
  track?: string;       // audio src
  label?: string;       // small caption under it
}
const {
  side = "SIDE A",
  title = "THE RECEPTION",
  track = "/audio/drew-salsa-60.mp3",
  label = "tap the record",
} = Astro.props;
---
<div class="tt" data-turntable data-track={track}>
  <div class="tt__platter" data-platter>
    <Record side={side} title={title} />
    <svg class="tonearm" viewBox="0 0 200 200" aria-hidden="true">
      <circle cx="172" cy="30" r="12" fill="#1B1714" />
      <circle cx="172" cy="30" r="5" fill="#F0502E" />
      <line x1="172" y1="30" x2="120" y2="98" stroke="#1B1714" stroke-width="5.5" stroke-linecap="round" />
      <rect x="110" y="90" width="18" height="9" rx="2" fill="#1B1714" transform="rotate(38 120 98)" />
    </svg>
  </div>

  <button class="tt__btn" data-toggle aria-pressed="false" aria-label="Play Drew's salsa mix">
    <span class="tt__btn-ico" data-ico>
      <svg class="ico-play" viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5v14l11-7z" fill="currentColor"/></svg>
      <svg class="ico-pause" viewBox="0 0 24 24" aria-hidden="true"><path d="M7 5h3.5v14H7zM13.5 5H17v14h-3.5z" fill="currentColor"/></svg>
    </span>
    <span class="tt__btn-txt" data-txt>{label}</span>
    <span class="tt__bars" aria-hidden="true"><i></i><i></i><i></i></span>
  </button>
</div>

<style>
  .tt { position: relative; display: grid; justify-items: center; gap: 16px; width: 100%; }
  .tt__platter { position: relative; width: min(92%, 420px); aspect-ratio: 1; }
  .tt__platter .platter { width: 100%; height: 100%; will-change: transform; }
  /* rotation is driven by JS (rAF) via --rot so it NEVER jumps on scroll */
  .tt__platter .spin { animation: none !important; transform: rotate(var(--rot, 0deg)); transform-origin: 50% 50%; }
  .tonearm {
    position: absolute; inset: 0; width: 100%; height: 100%;
    transform-origin: 86.5% 15.5%; transform: rotate(-24deg);
    transition: transform 1.1s var(--ease); z-index: 3; pointer-events: none;
  }
  .tt[data-playing="true"] .tonearm,
  .tt[data-cued="true"] .tonearm { transform: rotate(0deg); }

  .tt__btn {
    display: inline-flex; align-items: center; gap: 11px;
    font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--ink);
    background: var(--paper-2); border: 2px solid var(--ink);
    border-radius: 999px; padding: 8px 16px 8px 10px;
    box-shadow: 3px 3px 0 var(--ink);
    transition: transform 0.14s var(--ease), box-shadow 0.14s var(--ease), background 0.18s;
  }
  .tt__btn:hover { transform: translate(-2px, -2px); box-shadow: 5px 5px 0 var(--ink); }
  .tt__btn:active { transform: translate(2px, 2px); box-shadow: 1px 1px 0 var(--ink); }
  .tt__btn-ico {
    width: 30px; height: 30px; flex: none; border-radius: 50%;
    display: grid; place-items: center; background: var(--tangerine); color: var(--cream);
  }
  .tt__btn-ico svg { width: 14px; }
  .tt__btn-ico .ico-pause { display: none; }
  .tt[data-playing="true"] .tt__btn-ico .ico-play { display: none; }
  .tt[data-playing="true"] .tt__btn-ico .ico-pause { display: block; }
  .tt[data-playing="true"] .tt__btn-ico { background: var(--pine); }

  /* little "now playing" sound bars inside the button when playing */
  .tt__bars { display: none; align-items: flex-end; gap: 2px; height: 0.9em; margin-left: 2px; }
  .tt[data-playing="true"] .tt__bars { display: inline-flex; }
  .tt__bars i { width: 3px; background: var(--pine); height: 100%; transform-origin: bottom; animation: ttbar 0.8s ease-in-out infinite alternate; }
  .tt__bars i:nth-child(2){ animation-delay: 0.2s; }
  .tt__bars i:nth-child(3){ animation-delay: 0.4s; }
  @keyframes ttbar { from { transform: scaleY(0.25); } to { transform: scaleY(1); } }

  @media (prefers-reduced-motion: reduce) {
    .tt__bars i { animation: none; }
    .tonearm { transition: none; }
  }
</style>

<script>
  function initTurntables() {
    document.querySelectorAll<HTMLElement>("[data-turntable]").forEach((tt) => {
      if (tt.dataset.init === "1") return;
      tt.dataset.init = "1";

      const platter = tt.querySelector<HTMLElement>("[data-platter]");
      const spin = tt.querySelector<SVGElement>(".spin") as SVGElement | null;
      const btn = tt.querySelector<HTMLButtonElement>("[data-toggle]");
      const txt = tt.querySelector<HTMLElement>("[data-txt]");
      const src = tt.dataset.track || "";
      const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;

      // ---- smooth rotation via rAF (decoupled from scroll → no skipping) ----
      const IDLE = 60;   // deg/sec resting spin
      const PLAY = 240;  // deg/sec while the track is playing
      let speed = IDLE;
      let target = IDLE;
      let angle = 0;
      let last = 0;
      let rafId = 0;

      const frame = (t: number) => {
        if (!last) last = t;
        const dt = (t - last) / 1000;
        last = t;
        // ease current speed toward target so changes never jump
        speed += (target - speed) * Math.min(1, dt * 4);
        angle = (angle + speed * dt) % 360;
        if (spin) spin.style.setProperty("--rot", angle + "deg");
        rafId = requestAnimationFrame(frame);
      };

      const startLoop = () => { if (!rafId && !reduce) { last = 0; rafId = requestAnimationFrame(frame); } };
      const stopLoop = () => { if (rafId) { cancelAnimationFrame(rafId); rafId = 0; } };

      // Only spin while on screen (saves battery, still seamless)
      const vis = new IntersectionObserver((ents) => {
        ents.forEach((e) => {
          if (e.isIntersecting) { tt.dataset.cued = "true"; startLoop(); }
          else if (tt.dataset.playing !== "true") stopLoop();
        });
      }, { threshold: 0.15 });
      vis.observe(tt);

      // ---- audio ----
      let audio: HTMLAudioElement | null = null;
      const ensureAudio = () => {
        if (!audio && src) {
          audio = new Audio(src);
          audio.preload = "none";
          audio.addEventListener("ended", () => setPlaying(false));
        }
        return audio;
      };

      const setPlaying = (on: boolean) => {
        tt.dataset.playing = String(on);
        btn?.setAttribute("aria-pressed", String(on));
        target = on ? PLAY : IDLE;
        if (txt) txt.textContent = on ? "now playing — drew's salsa" : "tap the record";
        if (on) startLoop();
      };

      // pause every OTHER turntable's audio (only one song at a time)
      const stopOthers = () => {
        document.querySelectorAll<HTMLElement>('[data-turntable][data-playing="true"]').forEach((other) => {
          if (other !== tt) (other.querySelector<HTMLButtonElement>("[data-toggle]"))?.click();
        });
      };

      const toggle = () => {
        const a = ensureAudio();
        if (!a) return;
        if (a.paused) {
          stopOthers();
          a.play().then(() => setPlaying(true)).catch(() => setPlaying(false));
        } else {
          a.pause();
          setPlaying(false);
        }
      };

      btn?.addEventListener("click", toggle);
      platter?.addEventListener("click", toggle);
      platter?.style.setProperty("cursor", "pointer");

      // pause audio if user leaves the tab
      document.addEventListener("visibilitychange", () => {
        if (document.hidden && audio && !audio.paused) { audio.pause(); setPlaying(false); }
      });

      if (reduce && spin) spin.style.setProperty("--rot", "0deg");
    });
  }
  initTurntables();
  document.addEventListener("astro:after-swap", initTurntables);
</script>
