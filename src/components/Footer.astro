---
import { CONTACT, SOCIALS, TRACKS } from "../lib/site";
const year = 2026;
const explore = [
  { href: "/weddings", label: "Weddings" },
  { href: "/about", label: "My Story" },
  { href: "/build-your-floor", label: "Build Your Floor" },
  { href: "/reviews", label: "Real Couples" },
  { href: "/faq", label: "FAQ" },
  { href: "/check-availability", label: "Check Your Date" },
];
const iconPath: Record<string, string> = {
  ig: "M12 2.2c3.2 0 3.6 0 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s0 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23a3.7 3.7 0 0 1-.9 1.38 3.7 3.7 0 0 1-1.38.9c-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58 0-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.21 15.58 2.2 15.2 2.2 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.43-.16 1.06-.36 2.23-.41C8.42 2.2 8.8 2.2 12 2.2m0 3.65A6.15 6.15 0 1 0 18.15 12 6.15 6.15 0 0 0 12 5.85m0 2.15a4 4 0 1 1 0 8 4 4 0 0 1 0-8m6.4-3.9a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88",
  tt: "M16.6 5.82A4.28 4.28 0 0 1 15.54 3h-3.1v12.4a2.6 2.6 0 1 1-2.6-2.6c.27 0 .53.04.78.12V9.72a5.8 5.8 0 0 0-.78-.05A5.7 5.7 0 1 0 15.5 15.4V9.01a7.36 7.36 0 0 0 4.3 1.38V7.3a4.28 4.28 0 0 1-3.2-1.48",
  yt: "M23 7.5a3 3 0 0 0-2.1-2.1C19 4.9 12 4.9 12 4.9s-7 0-8.9.5A3 3 0 0 0 1 7.5 31 31 0 0 0 .5 12 31 31 0 0 0 1 16.5a3 3 0 0 0 2.1 2.1c1.9.5 8.9.5 8.9.5s7 0 8.9-.5a3 3 0 0 0 2.1-2.1 31 31 0 0 0 .5-4.5 31 31 0 0 0-.5-4.5M9.75 15.02V8.98L15.5 12z",
  mc: "M7.5 17a4.5 4.5 0 0 1-.5-8.97A6 6 0 0 1 18.2 9.2 4 4 0 0 1 17.5 17z",
  sc: "M2 12h2v6H2zM6 9h2v9H6zM10 7h2v11h-2zM14 9h2v9h-2zM18 6h2v12h-2z",
};
---
<footer class="foot">
  <div class="wrap foot__grid">
    <div class="foot__brand">
      <span class="brand">
        <svg class="brand__rec" viewBox="0 0 60 60" aria-hidden="true">
          <circle cx="30" cy="30" r="29" fill="#0e0c0b"/>
          <circle cx="30" cy="30" r="22" fill="none" stroke="#5a544d" stroke-width="0.8"/>
          <circle cx="30" cy="30" r="11" fill="#F0502E"/>
          <circle cx="30" cy="30" r="2.4" fill="#F6EEE2"/>
        </svg>
        DREW SEGURA
      </span>
      <p>the wedding dj for couples who want a packed floor, not a polite one. bilingual EN/ES. miami, fort lauderdale, the keys & wherever the party is.</p>
      <div class="socials">
        {SOCIALS.map((s) => (
          <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label}>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d={iconPath[s.icon]}/></svg>
          </a>
        ))}
      </div>
    </div>

    <div>
      <h4>Explore</h4>
      <ul>{explore.map((l) => <li><a href={l.href}>{l.label}</a></li>)}</ul>
    </div>

    <div>
      <h4>The Set</h4>
      <ul>{TRACKS.map((t) => <li><a href={`/weddings#${t.slug}`}>{t.t}</a></li>)}</ul>
    </div>

    <div>
      <h4>Book Drew</h4>
      <ul>
        <li><a href={`tel:${CONTACT.phoneDial}`}>{CONTACT.phoneDisplay}</a></li>
        <li><a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a></li>
        <li><a href="/check-availability" class="tlink" style="color:var(--tangerine)">Check your date →</a></li>
        <li style="color:rgba(246,238,226,0.55);font-size:.85rem;margin-top:6px">{CONTACT.areas.join(" · ")}</li>
      </ul>
    </div>
  </div>

  <div class="wrap foot__bar">
    <span>© {year} DJ Drew Segura · An <a class="tlink" style="color:rgba(246,238,226,0.8)" href={CONTACT.companyUrl} target="_blank" rel="noopener noreferrer">{CONTACT.company}</a> artist</span>
    <span class="welcome"><span class="flag" aria-hidden="true"></span> all are welcome on this dance floor</span>
    <span>pressed in miami · plays everywhere 🎧</span>
  </div>
</footer>
