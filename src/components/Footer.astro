---
const year = 2026;
const explore = [
  { href: "#the-set", label: "The Set" },
  { href: "#about", label: "Meet Drew" },
  { href: "#mixer", label: "Build Your Floor" },
  { href: "#couples", label: "Real Couples" },
  { href: "#faq", label: "FAQ" },
];
const services = [
  "Wedding DJ", "Bilingual MC / Host", "Ceremony Sound",
  "Cocktail Hour", "Uplighting & Monogram", "Cold Sparks & Clouds",
];
const socials = [
  { label: "Instagram", href: "https://instagram.com/djdrewofficial", icon: "ig" },
  { label: "TikTok", href: "https://tiktok.com/@djdrewofficiall", icon: "tt" },
  { label: "YouTube", href: "https://youtube.com/@djdrewofficial", icon: "yt" },
  { label: "MixCloud", href: "https://mixcloud.com/djdrewofficial", icon: "mc" },
  { label: "SoundCloud", href: "https://soundcloud.com/djdrewofficial", icon: "sc" },
];
---
<footer class="foot">
  <div class="wrap foot__grid">
    <div class="foot__brand">
      <span class="brand">
        <svg class="brand__rec" viewBox="0 0 60 60" aria-hidden="true">
          <circle cx="30" cy="30" r="29" fill="#0e0c0b"/>
          <circle cx="30" cy="30" r="22" fill="none" stroke="#5a544d" stroke-width="0.8"/>
          <circle cx="30" cy="30" r="11" fill="#F0502E"/>
          <circle cx="30" cy="30" r="2.4" fill="#F6EEE2"/>
        </svg>
        DREW SEGURA
      </span>
      <p>The wedding DJ for couples who want a packed floor, not a polite one. Bilingual EN/ES. Miami · Fort Lauderdale · the Keys & beyond.</p>
      <div class="socials">
        {socials.map((s) => (
          <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label}>
            {s.icon === "ig" && <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.2c3.2 0 3.6 0 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s0 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23a3.7 3.7 0 0 1-.9 1.38 3.7 3.7 0 0 1-1.38.9c-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58 0-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.43-.16 1.06-.36 2.23-.41C8.42 2.2 8.8 2.2 12 2.2m0 1.95c-3.15 0-3.52.01-4.76.07-.9.04-1.39.2-1.71.32-.43.17-.74.37-1.06.69-.32.32-.52.63-.69 1.06-.12.32-.28.81-.32 1.71-.06 1.24-.07 1.61-.07 4.76s.01 3.52.07 4.76c.04.9.2 1.39.32 1.71.17.43.37.74.69 1.06.32.32.63.52 1.06.69.32.12.81.28 1.71.32 1.24.06 1.61.07 4.76.07s3.52-.01 4.76-.07c.9-.04 1.39-.2 1.71-.32.43-.17.74-.37 1.06-.69.32-.32.52-.63.69-1.06.12-.32.28-.81.32-1.71.06-1.24.07-1.61.07-4.76s-.01-3.52-.07-4.76c-.04-.9-.2-1.39-.32-1.71a2.85 2.85 0 0 0-.69-1.06 2.85 2.85 0 0 0-1.06-.69c-.32-.12-.81-.28-1.71-.32-1.24-.06-1.61-.07-4.76-.07m0 3.32a4.53 4.53 0 1 1 0 9.06 4.53 4.53 0 0 1 0-9.06m0 1.95a2.58 2.58 0 1 0 0 5.16 2.58 2.58 0 0 0 0-5.16m5.77-2.17a1.06 1.06 0 1 1-2.12 0 1.06 1.06 0 0 1 2.12 0"/></svg>}
            {s.icon === "tt" && <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16.6 5.82A4.28 4.28 0 0 1 15.54 3h-3.1v12.4a2.6 2.6 0 1 1-2.6-2.6c.27 0 .53.04.78.12V9.72a5.8 5.8 0 0 0-.78-.05A5.7 5.7 0 1 0 15.5 15.4V9.01a7.36 7.36 0 0 0 4.3 1.38V7.3a4.28 4.28 0 0 1-3.2-1.48"/></svg>}
            {s.icon === "yt" && <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M23 7.5a3 3 0 0 0-2.1-2.1C19 4.9 12 4.9 12 4.9s-7 0-8.9.5A3 3 0 0 0 1 7.5 31 31 0 0 0 .5 12 31 31 0 0 0 1 16.5a3 3 0 0 0 2.1 2.1c1.9.5 8.9.5 8.9.5s7 0 8.9-.5a3 3 0 0 0 2.1-2.1 31 31 0 0 0 .5-4.5 31 31 0 0 0-.5-4.5M9.75 15.02V8.98L15.5 12z"/></svg>}
            {s.icon === "mc" && <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7.5 17a4.5 4.5 0 0 1-.5-8.97A6 6 0 0 1 18.2 9.2 4 4 0 0 1 17.5 17z"/></svg>}
            {s.icon === "sc" && <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="2" y="12" width="2" height="6" rx="1"/><rect x="6" y="9" width="2" height="9" rx="1"/><rect x="10" y="7" width="2" height="11" rx="1"/><rect x="14" y="9" width="2" height="9" rx="1"/><rect x="18" y="6" width="2" height="12" rx="1"/></svg>}
          </a>
        ))}
      </div>
    </div>

    <div>
      <h4>Explore</h4>
      <ul>{explore.map((l) => <li><a href={l.href}>{l.label}</a></li>)}</ul>
    </div>

    <div>
      <h4>The Set</h4>
      <ul>{services.map((s) => <li><span>{s}</span></li>)}</ul>
    </div>

    <div>
      <h4>Book Drew</h4>
      <ul>
        <li><a href="tel:+19542330698">954·233·0698</a></li>
        <li><a href="mailto:drew@xpressdjs.com">drew@xpressdjs.com</a></li>
        <li><a href="#request" class="tlink" style="color:var(--tangerine)">Check your date →</a></li>
        <li style="color:rgba(246,238,226,0.55);font-size:.85rem;margin-top:6px">Miami · Fort Lauderdale · Palm Beach · Boca · The Keys</li>
      </ul>
    </div>
  </div>

  <div class="wrap foot__bar">
    <span>© {year} DJ Drew Segura · An <a class="tlink" style="color:rgba(246,238,226,0.8)" href="https://xpressdjs.com" target="_blank" rel="noopener noreferrer">Xpress Entertainment</a> artist</span>
    <span class="welcome"><span class="flag" aria-hidden="true"></span> All are welcome on this dance floor</span>
    <span>Pressed in Miami · Plays everywhere 🎧</span>
  </div>
</footer>
