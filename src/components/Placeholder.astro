---
/**
 * Sized image placeholder. Shows the EXACT pixel dimensions a photo should be,
 * plus a description + suggested filename, so real photos drop in cleanly later.
 *
 * Usage:
 *   <Placeholder w={1200} h={1500} label="Drew on the decks, golden hour" file="hero-drew.jpg" />
 */
interface Props {
  w: number;
  h: number;
  label: string;
  file?: string;
  rounded?: string;     // e.g. "50%" for circles, "14px"
  class?: string;
  solid?: boolean;
}
const { w, h, label, file, rounded = "8px", class: cls = "", solid = false } = Astro.props;
const ratio = `${w} / ${h}`;
---
<figure
  class={`ph ${solid ? "ph--solid" : ""} ${cls}`}
  style={`aspect-ratio:${ratio}; border-radius:${rounded};`}
  role="img"
  aria-label={`Photo placeholder: ${label}`}
>
  <div class="ph__inner">
    <svg class="ph__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M3 8.5A2.5 2.5 0 0 1 5.5 6h1l1-1.6A1 1 0 0 1 9.3 4h5.4a1 1 0 0 1 .8.4L16.5 6h2A2.5 2.5 0 0 1 21 8.5v8A2.5 2.5 0 0 1 18.5 19h-13A2.5 2.5 0 0 1 3 16.5z"/>
      <circle cx="12" cy="12" r="3.4"/>
    </svg>
    <span class="ph__label">{label}</span>
    <span class="ph__dim">{w}×{h}px{file ? ` · ${file}` : ""}</span>
  </div>
</figure>
