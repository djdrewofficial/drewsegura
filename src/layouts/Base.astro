---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const {
  title = "DJ Drew Segura — Miami & Fort Lauderdale Wedding DJ",
  description = "Bilingual (EN/ES) wedding DJ + MC keeping South Florida dance floors packed. 150+ weddings a year, ★★★★★ rated. Check your date with DJ Drew Segura.",
  ogImage = "/og.svg",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://djdrewofficial.com").href;
const ogAbs = new URL(ogImage, Astro.site ?? "https://djdrewofficial.com").href;

const ld = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "MusicGroup"],
  name: "DJ Drew Segura",
  description,
  image: ogAbs,
  url: canonical,
  telephone: "+1-954-233-0698",
  email: "drew@xpressdjs.com",
  priceRange: "$$$",
  genre: ["Reggaeton", "Salsa", "Merengue", "Open Format", "Hip-Hop", "EDM", "Pop"],
  address: {
    "@type": "PostalAddress",
    addressLocality: "Miami",
    addressRegion: "FL",
    addressCountry: "US",
  },
  areaServed: [
    "Miami, FL", "Fort Lauderdale, FL", "Miami Beach, FL",
    "Palm Beach, FL", "Boca Raton, FL", "The Florida Keys",
  ],
  sameAs: [
    "https://instagram.com/djdrewofficial",
    "https://tiktok.com/@djdrewofficiall",
    "https://youtube.com/@djdrewofficial",
    "https://mixcloud.com/djdrewofficial",
    "https://soundcloud.com/djdrewofficial",
  ],
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "5.0",
    reviewCount: "100",
  },
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#F3EBDD" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogAbs} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogAbs} />

    <!-- fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,300..800&family=Hanken+Grotesk:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <!-- mark JS early so reveal-hidden styles only apply when we can un-hide them (no FOUC, crawler-safe) -->
    <script is:inline>document.documentElement.classList.add("js");</script>

    <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link" style="position:absolute;left:-999px;top:0;background:var(--ink);color:var(--cream);padding:10px 16px;z-index:200;border-radius:0 0 8px 0" onfocus="this.style.left='0'" onblur="this.style.left='-999px'">Skip to content</a>
    <slot />

    <script>
      // Site-wide scroll reveal (clip-wipe). Runs on every page that uses Base.
      const reveals = document.querySelectorAll("[data-reveal]");
      const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (reduce) {
        reveals.forEach((el) => el.classList.add("is-in"));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) { e.target.classList.add("is-in"); io.unobserve(e.target); }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
        );
        reveals.forEach((el) => io.observe(el));
        // failsafe: never leave content hidden once the page has settled
        addEventListener("load", () =>
          setTimeout(() => reveals.forEach((el) => el.classList.add("is-in")), 1500)
        );
      }
    </script>
  </body>
</html>
