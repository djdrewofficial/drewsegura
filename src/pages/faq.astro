---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import CtaBand from "../components/CtaBand.astro";
import { FAQS, CONTACT } from "../lib/site";

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: FAQS.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---
<Base
  title="Wedding DJ FAQ — Pricing, Bilingual MC & Booking | DJ Drew Segura"
  description="Straight answers on wedding DJ cost in South Florida, bilingual English/Spanish MC hosting, song requests, travel, and how far ahead to book Miami & Fort Lauderdale wedding DJ Drew Segura."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} slot="head" />
  <Nav />
  <main id="main">
    <header class="page-hero section--tight">
      <div class="wrap">
        <p class="kicker" data-reveal>Liner notes · read before you book</p>
        <h1 class="display" style="font-size:clamp(2.6rem,7vw,5.4rem);margin:16px 0 18px" data-reveal data-d="1">
          the honest<br /><span class="mark">q &amp; a</span>.
        </h1>
        <p class="lead" data-reveal data-d="2" style="max-width:60ch">
          no sales fluff, no dodging the money question. here's what couples actually ask me, answered the
          way i'd answer it over a coffee. don't see yours? just text me at
          <a class="tlink" href={`sms:${CONTACT.phoneSms}`}>{CONTACT.phoneDisplay}</a>.
        </p>
      </div>
    </header>

    <section class="section--tight" style="padding-bottom:clamp(50px,7vw,90px)">
      <div class="wrap" style="max-width:880px">
        <div class="faq" data-reveal>
          {FAQS.map((f, i) => (
            <details open={i === 0}>
              <summary>{f.q}<span class="sign" aria-hidden="true"></span></summary>
              <div class="faq__a"><p>{f.a}</p></div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <CtaBand kicker="got your answers" heading="cool — let's check if your date's open." />
  </main>
  <Footer />
</Base>
