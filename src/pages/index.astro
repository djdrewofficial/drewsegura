---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Placeholder from "../components/Placeholder.astro";
import Turntable from "../components/Turntable.astro";
import Equalizer from "../components/Equalizer.astro";
import CtaBand from "../components/CtaBand.astro";
import { VENUES, TRACKS, REVIEWS, CONTACT } from "../lib/site";

const specs = [
  ["years on the 1s", "15+"],
  ["weddings a year", "150+"],
  ["dancing humans", "3,000+"],
  ["dates missed", "0"],
  ["languages", "EN / ES"],
];

const rider = [
  "yeah, i'll play your abuela's salsa request — and i'll make it land",
  "i read the floor as it happens. no dead sets, no awkward silences",
  "one mic, two languages, both sides of the family hyped the same",
  "backup gear for the backup gear. i don't gamble with your day",
  "i know exactly when to drop juan luis guerra and when to drop bad bunny",
];

const gallery = [
  { cls: "g-a", w: 1200, h: 900, label: "First dance + cold sparks", roll: "ROLL 01 / FRAME 04", file: "dance-coldsparks.jpg" },
  { cls: "g-b", w: 900, h: 1100, label: "Packed floor, hands up", roll: "ROLL 01 / FRAME 09", file: "packed-floor.jpg" },
  { cls: "g-c", w: 800, h: 950, label: "Bride + abuela, la hora loca", roll: "ROLL 02 / FRAME 02", file: "abuela-horaloca.jpg" },
  { cls: "g-d", w: 1100, h: 850, label: "Grand entrance blur", roll: "ROLL 02 / FRAME 07", file: "grand-entrance.jpg" },
  { cls: "g-e", w: 1000, h: 900, label: "Drew on the mic", roll: "ROLL 03 / FRAME 01", file: "drew-mic.jpg" },
  { cls: "g-f", w: 1100, h: 900, label: "Confetti drop, last song", roll: "ROLL 03 / FRAME 12", file: "confetti.jpg" },
];

const steps = [
  { t: "check your date", d: "tell me who, where and when. i get back to you within 24 hours — usually way faster, sometimes with a bad pun. if i'm free, you get real pricing right away." },
  { t: "plan it together", d: "we map out your timeline, your must-plays and your do-NOT-plays in an easy planning app. wanna be hands-on or just hand me the keys? totally your call." },
  { t: "pack the floor", d: "i show up early and dialed in, with backups for the backups. you dance, your family dances, and nobody important spends the night sitting down." },
];

const homeReviews = REVIEWS.slice(0, 3);
---
<Base>
  <Nav />
  <main id="main">

    <!-- ============ HERO ============ -->
    <header class="hero section--tight" id="top">
      <div class="wrap hero__grid">
        <div class="hero__copy">
          <p class="kicker hero__eyebrow">Bilingual Wedding DJ + MC · Miami &amp; Fort Lauderdale</p>
          <h1 class="display hero__title" data-reveal>
            nobody remembers<br />the centerpieces.<br />
            <span class="line2">they remember the <span class="mark">floor</span>.</span>
          </h1>
          <p class="lead hero__lead" data-reveal data-d="1">
            hey, i'm <strong>Drew Segura</strong>. i'm a bilingual (english &amp; spanish) wedding dj and mc
            here in south florida, and i've spent 15 years figuring out one thing — how to get
            <em>everyone</em> on the floor and keep them there. your tía, your college friends, your
            brand-new in-laws, all going off to the same song. from the <em>"i do"</em> straight through
            <em>la hora loca</em>.
          </p>
          <div class="btn-row hero__cta" data-reveal data-d="2">
            <a href="/check-availability" class="btn btn--primary">Check your date <span class="arr">→</span></a>
            <a href="/build-your-floor" class="btn">Build your dance floor</a>
          </div>
          <div class="hero__trust" data-reveal data-d="3">
            <div class="trust-item">
              <span class="stars" aria-label="5 out of 5 stars">★★★★★</span>
              <span>100+ happy couples</span>
            </div>
            <div class="trust-item"><b>150+</b><span>weddings a year</span></div>
            <div class="trust-item"><b>15 yrs</b><span>behind the decks</span></div>
            <div class="trust-item"><b>EN / ES</b><span>bilingual host</span></div>
          </div>
        </div>

        <div class="hero__stage">
          <Turntable side="SIDE A" title="THE RECEPTION" label="tap to hear me cook" />
          <span class="hero__floatnote mono" style="position:absolute;bottom:-6px;right:2px">that's a real mix · turn it up 🔊</span>
        </div>
      </div>

      <div class="wrap">
        <span class="cue"><span class="needle"></span> drop the needle — scroll</span>
      </div>
    </header>

    <!-- ============ HEARD AT ============ -->
    <section class="heardat" aria-label="Venues">
      <div class="wrap heardat__inner">
        <span class="heardat__label">★ heard at south florida's best rooms</span>
        <ul class="heardat__list">
          {VENUES.map((v) => <li>{v}</li>)}
        </ul>
      </div>
    </section>

    <!-- ============ ABOUT TEASER ============ -->
    <section class="section" id="about">
      <div class="wrap">
        <div class="shead" data-reveal>
          <div class="shead__top">
            <h2 class="h-xl">i don't play playlists.<br />i read the room.</h2>
            <span class="shead__side">the short version</span>
          </div>
        </div>

        <div class="about__grid">
          <div data-reveal>
            <div style="position:relative">
              <Placeholder w={900} h={1100} label="Drew Segura — portrait / on the mic, mid-hype" file="drew-portrait.jpg" rounded="14px" />
              <span class="note" style="position:absolute;bottom:-30px;right:6px;transform:rotate(-2deg)">yeah that's his actual face when the beat drops</span>
            </div>
            <dl class="specs" style="margin-top:46px">
              <div class="specs__head"><span>track listing — the specs</span><span>33⅓</span></div>
              {specs.map(([k, v]) => (
                <div class="specs__row"><dt>{k}</dt><dd>{v}</dd></div>
              ))}
            </dl>
          </div>

          <div data-reveal data-d="1">
            <p class="lead" style="margin-bottom:20px">
              i grew up in a dominican-american house where merengue, freestyle and 2000s hip-hop all lived
              on the same radio dial. honestly? that's still exactly how i dj a wedding.
            </p>
            <p style="margin-bottom:18px">
              i've been doing this since i was 13 — bedroom practice, late-night live streams, las olas
              nightclubs, and lgbtq residencies all over the country, including my weekly night at hunters
              in wilton manors. all of it was really just training for the rooms i love most, which is
              <strong>weddings</strong>. i started <a class="tlink" href={CONTACT.companyUrl} target="_blank" rel="noopener noreferrer">Xpress DJs</a> back in 2016 and these days
              we play 150+ south florida weddings a year.
            </p>
            <p>
              being open-format means i'm not boxed into one genre or one generation. reggaetón into a
              2000s throwback into a salsa your tía will lose it over into the edm your friends came for —
              all mixed live, read off the actual crowd in front of me. never a pre-made playlist running
              on autopilot.
            </p>

            <h3 class="h-md" style="margin:30px 0 4px">a few things you can count on</h3>
            <ul class="rider">
              {rider.map((r) => <li>{r}</li>)}
            </ul>

            <div class="btn-row" style="margin-top:30px">
              <a href="/about" class="btn btn--pine">read my full story <span class="arr">→</span></a>
              <a href="/weddings" class="tlink">or see how a wedding goes →</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="wrap"><hr class="rule" /></div>

    <!-- ============ THE SET (tracklist teaser) ============ -->
    <section class="section" id="the-set">
      <div class="wrap">
        <div class="shead" data-reveal>
          <div class="shead__top">
            <h2 class="h-xl">the full set.<br />side a to last call.</h2>
            <span class="shead__side">the night, as an album</span>
          </div>
          <p class="lead">here's everything that goes into a wedding with me, ceremony to last call, laid out like the record it deserves to be. tap any track for the details.</p>
        </div>

        <ol class="tracks">
          {TRACKS.map((tr, i) => (
            <li class="track" data-reveal data-d={String(i % 3)}>
              <span class="track__no">{tr.no}</span>
              <a class="track__main" href={`/weddings#${tr.slug}`}>
                <h3>{tr.t}</h3>
                <p>{tr.d}</p>
                <div class="tags">{tr.tags.map((t) => <span class="tag">{t}</span>)}</div>
              </a>
              <div class="track__time">
                <span class="rt">{tr.rt}</span>
                <span class="track__play" aria-hidden="true">
                  <svg class="ico-play" viewBox="0 0 24 24" fill="#1B1714"><path d="M8 5v14l11-7z" /></svg>
                  <span class="ico-eq"><Equalizer /></span>
                </span>
              </div>
            </li>
          ))}
        </ol>
        <div class="btn-row" style="margin-top:34px">
          <a href="/weddings" class="btn btn--ink">see the whole wedding experience <span class="arr">→</span></a>
        </div>
      </div>
    </section>

    <!-- ============ BUILD TEASER ============ -->
    <section class="section bg-strip">
      <div class="wrap">
        <div class="teaser">
          <div data-reveal>
            <p class="kicker">Interactive · the fun part</p>
            <h2 class="h-xl" style="margin:12px 0 16px">build your dance floor.<br />see what i'd do with it.</h2>
            <p class="lead">pick every genre your crowd actually moves to and watch your floor fill up in real time. it's a five-second preview of the chaos — and a pretty good way to tell me exactly who you are.</p>
            <div class="btn-row" style="margin-top:24px">
              <a href="/build-your-floor" class="btn btn--primary">build your floor <span class="arr">→</span></a>
            </div>
          </div>
          <div data-reveal data-d="1" class="teaser__art">
            <div class="eqcard">
              <div class="eqcard__bar">DREW-OS · floor preview</div>
              <div class="eqcard__body">
                {["Reggaetón","Salsa","2000s","EDM","Bachata","Afrobeats"].map((g) => <span class="chip" aria-hidden="true">{g}</span>)}
              </div>
              <div class="eqcard__wall" aria-hidden="true">{Array.from({length:18}).map(() => <i></i>)}</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ REVIEWS TEASER ============ -->
    <section class="section" id="couples">
      <div class="wrap">
        <div class="shead" data-reveal>
          <div class="shead__top">
            <h2 class="h-xl">real couples.<br />real packed floors.</h2>
            <span class="shead__side">admit two · ★★★★★</span>
          </div>
        </div>
        <div class="tickets">
          {homeReviews.map((c, i) => (
            <figure class="ticket" data-reveal data-d={String(i)}>
              <div class="ticket__stub"><span>{c.source}</span><span class="stars">★★★★★</span></div>
              <blockquote class="ticket__quote">"{c.q}"</blockquote>
              <figcaption class="ticket__who">
                <Placeholder w={120} h={120} label="couple" rounded="50%" class="ph" />
                <span><b>{c.n}</b><span>{c.v} · {c.date}</span></span>
              </figcaption>
            </figure>
          ))}
        </div>
        <div class="btn-row" style="margin-top:26px">
          <a href="/reviews" class="btn btn--pine">read more reviews <span class="arr">→</span></a>
          <span class="note" style="margin:0">100+ five-star reviews across google, zola &amp; the knot — these are just three</span>
        </div>
      </div>
    </section>

    <!-- ============ GALLERY ============ -->
    <section class="section" aria-label="Gallery">
      <div class="wrap">
        <div class="shead" data-reveal>
          <div class="shead__top">
            <h2 class="h-xl">receipts from the floor.</h2>
            <span class="shead__side">side b · the proof sheet</span>
          </div>
        </div>
        <div class="sheet">
          {gallery.map((g, i) => (
            <figure class={`frame ${g.cls}`} data-reveal data-d={String(i % 3)}>
              <Placeholder w={g.w} h={g.h} label={g.label} file={g.file} rounded="0" />
              <figcaption><span>{g.roll}</span><span class="dot-grade">●●●●●</span></figcaption>
            </figure>
          ))}
        </div>
        <p class="note" style="margin-top:20px">*every frame is a sized, ready-to-drop placeholder — swap in your real wedding photos and it just works</p>
      </div>
    </section>

    <!-- ============ STEPS ============ -->
    <section class="section">
      <div class="wrap">
        <div class="shead" data-reveal>
          <div class="shead__top">
            <h2 class="h-xl">how booking works.</h2>
            <span class="shead__side">three cue points</span>
          </div>
        </div>
        <div class="steps">
          {steps.map((s, i) => (
            <article class="step" data-reveal data-d={String(i)}>
              <span class="step__no">{String(i + 1).padStart(2, "0")}</span>
              <h3>{s.t}</h3>
              <p>{s.d}</p>
            </article>
          ))}
        </div>
        <div class="btn-row" style="margin-top:34px;justify-content:center">
          <a href="/check-availability" class="btn btn--primary">start step one → check your date</a>
        </div>
      </div>
    </section>

    <CtaBand />
  </main>

  <Footer />
  <canvas id="confetti" aria-hidden="true"></canvas>
</Base>

<script>
  // ---------- confetti (no deps) ----------
  const canvas = document.getElementById("confetti") as HTMLCanvasElement | null;
  const ctx = canvas?.getContext("2d");
  const COLORS = ["#F0502E", "#124C44", "#B5832B", "#1B1714", "#F6EEE2"];
  let pieces: { x: number; y: number; r: number; c: string; vx: number; vy: number; rot: number; vr: number }[] = [];
  let raf = 0;
  function size() { if (canvas) { canvas.width = innerWidth; canvas.height = innerHeight; } }
  size(); addEventListener("resize", size);
  function burst() {
    if (!canvas || !ctx) return;
    if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    for (let i = 0; i < 140; i++) {
      pieces.push({
        x: innerWidth / 2 + (Math.random() - 0.5) * 240, y: innerHeight / 3,
        r: 4 + Math.random() * 7, c: COLORS[(Math.random() * COLORS.length) | 0],
        vx: (Math.random() - 0.5) * 11, vy: -6 - Math.random() * 9,
        rot: Math.random() * 6.28, vr: (Math.random() - 0.5) * 0.4,
      });
    }
    if (!raf) tick();
  }
  function tick() {
    if (!canvas || !ctx) return;
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    pieces.forEach((p) => {
      p.vy += 0.32; p.x += p.vx; p.y += p.vy; p.rot += p.vr;
      ctx.save(); ctx.translate(p.x, p.y); ctx.rotate(p.rot); ctx.fillStyle = p.c;
      ctx.fillRect(-p.r / 2, -p.r / 2, p.r, p.r * 0.6); ctx.restore();
    });
    pieces = pieces.filter((p) => p.y < canvas.height + 40);
    raf = pieces.length ? requestAnimationFrame(tick) : 0;
  }
  (window as any).__burst = burst;

  // ---------- konami easter egg ----------
  const code = ["ArrowUp","ArrowUp","ArrowDown","ArrowDown","ArrowLeft","ArrowRight","ArrowLeft","ArrowRight","b","a"];
  let idx = 0;
  addEventListener("keydown", (e) => {
    idx = e.key.toLowerCase() === code[idx].toLowerCase() ? idx + 1 : 0;
    if (idx === code.length) {
      idx = 0; burst();
      const t = document.createElement("div");
      t.textContent = "🎧 ENCORE! you found the secret track.";
      t.style.cssText = "position:fixed;left:50%;top:24px;transform:translateX(-50%);z-index:120;background:var(--ink);color:var(--cream);font-family:var(--font-mono);font-size:.85rem;padding:12px 18px;border-radius:10px;box-shadow:var(--shadow)";
      document.body.appendChild(t);
      setTimeout(() => t.remove(), 3200);
    }
  });
</script>
